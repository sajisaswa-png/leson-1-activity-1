print("Simple Calculator")

a = float(input("Enter first number: "))
b = float(input("Enter second number: "))
c = float(input("Enter third number: "))

op = input("Choose operation (+, -, *, /): ")

if op == "+":
    print("Result:", a + b +c)
elif op == "-":
    print("Result:", a - b - c)
elif op == "*":
    print("Result:", a * b * c)
elif op == "/":
    if b != 0:
        print("Result:", a / b / c )
    else:
        print("Cannot divide by zero!")
else:
    print("Invalid operation")